generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id         String    @id @default(uuid())
  name       String
  monthlyFee Float     @default(80.0)
  isActive   Boolean   @default(true)
  phone      String?
  payments    Payment[]
  attendances Attendance[]
  createdAt   DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Payment {
  id         String   @id @default(uuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id])
  month      String   // format "MM/YYYY"
  amountPaid Float
  status     String   // "PAID" | "PENDING"
  paidAt     DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CostPayment {
  id         String   @id @default(uuid())
  name       String   // "Sampaio", "Quadra", etc.
  value      Float
  month      String   // format "MM/YYYY"
  status     String   // "PAID" | "PENDING"
  paidAt     DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model TrainingDay {
  id         String   @id @default(uuid())
  month      String   // format "MM/YYYY"
  day        Int
  date       DateTime
  isClosed   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attendances Attendance[]
}

model Goal {
  id            String   @id @default(uuid())
  title         String
  targetAmount  Float
  currentAmount Float    @default(0.0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Attendance {
  id            String      @id @default(uuid())
  studentId     String
  student       Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  trainingDayId String
  trainingDay   TrainingDay @relation(fields: [trainingDayId], references: [id], onDelete: Cascade)
  isPresent     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([studentId, trainingDayId])
}
